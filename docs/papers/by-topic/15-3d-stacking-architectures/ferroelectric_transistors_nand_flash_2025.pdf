            <li class="c-article-subject-list__subject"><a href="/subjects/electrical-and-electronic-engineering" data-track="click" data-track-action="view subject" data-track-label="link">Electrical and electronic engineering</a></li><li class="c-article-subject-list__subject"><a href="/subjects/electronic-devices" data-track="click" data-track-action="view subject" data-track-label="link">Electronic devices</a></li><li class="c-article-subject-list__subject"><a href="/subjects/information-storage" data-track="click" data-track-action="view subject" data-track-label="link">Information storage</a></li>
