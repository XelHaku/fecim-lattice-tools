// Package crossbar implements ferroelectric crossbar array simulation.
package crossbar

import (
	"errors"
	"math"
)

// Solver errors
var (
	ErrConvergenceFailed    = errors.New("solver failed to converge")
	ErrMaxIterationsExceeded = errors.New("maximum iterations exceeded")
	ErrInvalidConfiguration  = errors.New("invalid solver configuration")
)

// SORConfig contains configuration for the Successive Over-Relaxation solver.
// SOR is more efficient than damped Jacobi for large arrays with high parasitic resistance.
// Ported from CrossSim's iterative solver approach.
type SORConfig struct {
	MaxIterations int     // Maximum solver iterations (default: 100)
	Tolerance     float64 // Convergence tolerance in volts (default: 1e-6)
	OmegaInitial  float64 // Initial relaxation factor (1.0-1.9 for SOR, <1.0 for under-relaxation)
	OmegaMin      float64 // Minimum omega before declaring divergence (default: 0.01)
	OmegaDecay    float64 // Decay factor when divergence detected (default: 0.95)
	AdaptiveOmega bool    // Auto-tune omega on divergence detection
}

// DefaultSORConfig returns default SOR solver configuration.
// These defaults are tuned for typical FeCIM crossbar arrays.
func DefaultSORConfig() *SORConfig {
	return &SORConfig{
		MaxIterations: 100,
		Tolerance:     1e-6,
		OmegaInitial:  1.0, // Start with standard relaxation
		OmegaMin:      0.01,
		OmegaDecay:    0.95, // Reduce omega by 5% on divergence
		AdaptiveOmega: true,
	}
}

// MVMResult contains the results of MVM computation with parasitic effects.
type MVMResult struct {
	OutputCurrents []float64   // Output currents at bit lines
	DeviceCurrents [][]float64 // Current through each device
	DeviceVoltages [][]float64 // Voltage across each device
	Iterations     int         // Number of iterations to converge
	Converged      bool        // Whether solver converged
	MaxError       float64     // Maximum voltage error at convergence
	FinalOmega     float64     // Final relaxation factor used
}

// ParasiticSolver implements the SOR-based iterative solver for crossbar arrays
// with parasitic (wire) resistance. Based on CrossSim's NonInterleaved_InputSource approach.
type ParasiticSolver struct {
	rows   int
	cols   int
	config *SORConfig

	// Normalized parasitic resistances (Rp/Rmin)
	RpRow float64 // Row (word line) parasitic resistance per cell
	RpCol float64 // Column (bit line) parasitic resistance per cell

	// Conductance matrix (normalized 0-1)
	conductances [][]float64
}

// NewParasiticSolver creates a new SOR-based parasitic solver.
func NewParasiticSolver(rows, cols int, config *SORConfig) (*ParasiticSolver, error) {
	if rows <= 0 || cols <= 0 {
		return nil, ErrInvalidConfiguration
	}
	if config == nil {
		config = DefaultSORConfig()
	}

	return &ParasiticSolver{
		rows:         rows,
		cols:         cols,
		config:       config,
		conductances: make([][]float64, rows),
	}, nil
}

// SetConductances sets the conductance matrix (normalized 0-1 values).
func (s *ParasiticSolver) SetConductances(g [][]float64) {
	s.conductances = make([][]float64, len(g))
	for i := range g {
		s.conductances[i] = make([]float64, len(g[i]))
		copy(s.conductances[i], g[i])
	}
}

// SetParasitics sets the parasitic resistance values.
// Values should be normalized by Rmin (e.g., Rp/Rmin).
func (s *ParasiticSolver) SetParasitics(rpRow, rpCol float64) {
	s.RpRow = rpRow
	s.RpCol = rpCol
}

// SolveMVM performs matrix-vector multiplication with parasitic resistance effects.
// Uses Successive Over-Relaxation (SOR) for iterative convergence.
//
// Algorithm (from CrossSim):
// 1. Initialize device voltages to applied voltages
// 2. Compute device currents: I = G × V
// 3. Compute cumulative currents along rows and columns
// 4. Compute parasitic voltage drops from cumulative currents
// 5. Calculate voltage error: V_error = V_applied - V_parasitic - V_device
// 6. Update device voltages with relaxation: V_new = V_old + omega × V_error
// 7. Repeat until converged or max iterations
func (s *ParasiticSolver) SolveMVM(appliedVoltages []float64) (*MVMResult, error) {
	if len(appliedVoltages) != s.cols {
		return nil, ErrInvalidConfiguration
	}

	// Initialize device voltages to applied voltages (initial guess)
	dV := make([][]float64, s.rows)
	for i := 0; i < s.rows; i++ {
		dV[i] = make([]float64, s.cols)
		for j := 0; j < s.cols; j++ {
			dV[i][j] = appliedVoltages[j]
		}
	}

	// Initialize device currents
	Ires := make([][]float64, s.rows)
	for i := 0; i < s.rows; i++ {
		Ires[i] = make([]float64, s.cols)
	}

	omega := s.config.OmegaInitial
	prevErr := math.MaxFloat64
	var finalErr float64

	for iter := 0; iter < s.config.MaxIterations; iter++ {
		// Step 1: Compute device currents (Ohm's law: I = G × V)
		for i := 0; i < s.rows; i++ {
			for j := 0; j < s.cols; j++ {
				g := s.conductances[i][j]
				if g < 1e-10 {
					g = 1e-10 // Avoid division issues
				}
				Ires[i][j] = g * dV[i][j]
			}
		}

		// Step 2: Compute cumulative currents along columns (from bit line ground to row)
		// IsumCol[i][j] = sum of currents from row 0 to row i in column j
		IsumCol := make([][]float64, s.rows)
		for i := 0; i < s.rows; i++ {
			IsumCol[i] = make([]float64, s.cols)
			for j := 0; j < s.cols; j++ {
				if i == 0 {
					IsumCol[i][j] = Ires[i][j]
				} else {
					IsumCol[i][j] = IsumCol[i-1][j] + Ires[i][j]
				}
			}
		}

		// Step 3: Compute cumulative currents along rows (from row driver to column)
		// IsumRow[i][j] = sum of currents from col j to last col in row i
		IsumRow := make([][]float64, s.rows)
		for i := 0; i < s.rows; i++ {
			IsumRow[i] = make([]float64, s.cols)
			for j := s.cols - 1; j >= 0; j-- {
				if j == s.cols-1 {
					IsumRow[i][j] = Ires[i][j]
				} else {
					IsumRow[i][j] = IsumRow[i][j+1] + Ires[i][j]
				}
			}
		}

		// Step 4: Compute parasitic voltage drops
		// Column drops (bit line): accumulate from ground (row 0) downward
		VdropsCol := make([][]float64, s.rows)
		for i := 0; i < s.rows; i++ {
			VdropsCol[i] = make([]float64, s.cols)
			for j := 0; j < s.cols; j++ {
				if i == 0 {
					VdropsCol[i][j] = 0
				} else {
					// Voltage rise on bit line from accumulated current
					VdropsCol[i][j] = VdropsCol[i-1][j] + s.RpCol*IsumCol[i-1][j]
				}
			}
		}

		// Row drops (word line): accumulate from driver (col 0) rightward
		VdropsRow := make([][]float64, s.rows)
		for i := 0; i < s.rows; i++ {
			VdropsRow[i] = make([]float64, s.cols)
			for j := 0; j < s.cols; j++ {
				if j == 0 {
					VdropsRow[i][j] = 0
				} else {
					// Voltage drop on word line from accumulated current
					VdropsRow[i][j] = VdropsRow[i][j-1] + s.RpRow*IsumRow[i][j]
				}
			}
		}

		// Step 5: Calculate voltage error
		// Effective device voltage = Applied - WL drop - BL rise
		maxErr := 0.0
		VerrMat := make([][]float64, s.rows)
		for i := 0; i < s.rows; i++ {
			VerrMat[i] = make([]float64, s.cols)
			for j := 0; j < s.cols; j++ {
				// Expected device voltage considering parasitics
				Vexpected := appliedVoltages[j] - VdropsRow[i][j] - VdropsCol[i][j]
				if Vexpected < 0 {
					Vexpected = 0
				}
				// Error = expected - current estimate
				VerrMat[i][j] = Vexpected - dV[i][j]
				if math.Abs(VerrMat[i][j]) > maxErr {
					maxErr = math.Abs(VerrMat[i][j])
				}
			}
		}
		finalErr = maxErr

		// Step 6: Check convergence
		if maxErr < s.config.Tolerance {
			return s.buildResult(dV, Ires, iter+1, true, maxErr, omega), nil
		}

		// Step 7: Detect divergence and adapt omega
		if s.config.AdaptiveOmega && iter > 5 && maxErr > prevErr {
			omega *= s.config.OmegaDecay
			if omega < s.config.OmegaMin {
				// Return partial result with unconverged flag
				return s.buildResult(dV, Ires, iter+1, false, maxErr, omega), ErrConvergenceFailed
			}
		}
		prevErr = maxErr

		// Step 8: SOR update
		for i := 0; i < s.rows; i++ {
			for j := 0; j < s.cols; j++ {
				dV[i][j] += omega * VerrMat[i][j]
				// Clamp to valid range
				if dV[i][j] < 0 {
					dV[i][j] = 0
				}
				if dV[i][j] > appliedVoltages[j] {
					dV[i][j] = appliedVoltages[j]
				}
			}
		}
	}

	return s.buildResult(dV, Ires, s.config.MaxIterations, false, finalErr, omega), ErrMaxIterationsExceeded
}

// buildResult constructs the MVMResult from solver state.
func (s *ParasiticSolver) buildResult(dV, Ires [][]float64, iters int, converged bool, maxErr, omega float64) *MVMResult {
	// Sum currents along columns to get output
	output := make([]float64, s.cols)
	for j := 0; j < s.cols; j++ {
		for i := 0; i < s.rows; i++ {
			output[j] += Ires[i][j]
		}
	}

	// Copy device data
	deviceCurrents := make([][]float64, s.rows)
	deviceVoltages := make([][]float64, s.rows)
	for i := 0; i < s.rows; i++ {
		deviceCurrents[i] = make([]float64, s.cols)
		deviceVoltages[i] = make([]float64, s.cols)
		copy(deviceCurrents[i], Ires[i])
		copy(deviceVoltages[i], dV[i])
	}

	return &MVMResult{
		OutputCurrents: output,
		DeviceCurrents: deviceCurrents,
		DeviceVoltages: deviceVoltages,
		Iterations:     iters,
		Converged:      converged,
		MaxError:       maxErr,
		FinalOmega:     omega,
	}
}

// SolveMVMWithFallback attempts SOR solver, falls back to damped Jacobi on failure.
// This provides robustness for edge cases where SOR may diverge.
func (s *ParasiticSolver) SolveMVMWithFallback(appliedVoltages []float64) (*MVMResult, error) {
	result, err := s.SolveMVM(appliedVoltages)
	if err == nil {
		return result, nil
	}

	// Fallback to damped Jacobi (use small omega)
	origOmega := s.config.OmegaInitial
	s.config.OmegaInitial = 0.5 // Under-relaxation for stability
	s.config.AdaptiveOmega = false

	result, err = s.SolveMVM(appliedVoltages)

	// Restore original config
	s.config.OmegaInitial = origOmega
	s.config.AdaptiveOmega = true

	return result, err
}

// ComputeIdealMVM computes ideal MVM without parasitic effects for comparison.
func (s *ParasiticSolver) ComputeIdealMVM(appliedVoltages []float64) []float64 {
	output := make([]float64, s.cols)
	for j := 0; j < s.cols; j++ {
		for i := 0; i < s.rows; i++ {
			output[j] += s.conductances[i][j] * appliedVoltages[j]
		}
	}
	return output
}

// ComputeAccuracyLoss calculates the accuracy loss due to parasitic effects.
// Returns the root mean square error between ideal and actual outputs.
func ComputeAccuracyLoss(ideal, actual []float64) float64 {
	if len(ideal) != len(actual) {
		return math.Inf(1)
	}

	var sumSqErr float64
	for i := range ideal {
		diff := ideal[i] - actual[i]
		sumSqErr += diff * diff
	}

	return math.Sqrt(sumSqErr / float64(len(ideal)))
}

// AnalyzeParasiticImpact runs the solver and returns detailed impact analysis.
type ParasiticImpact struct {
	Solver            *ParasiticSolver
	IdealOutput       []float64
	ActualOutput      []float64
	RMSError          float64
	MaxRelativeError  float64
	IterationsNeeded  int
	WorstCaseCell     [2]int
	WorstCaseDropPct  float64
}

// AnalyzeParasiticImpact performs comprehensive analysis of parasitic effects.
func (s *ParasiticSolver) AnalyzeParasiticImpact(appliedVoltages []float64) (*ParasiticImpact, error) {
	// Compute ideal (no parasitics)
	ideal := s.ComputeIdealMVM(appliedVoltages)

	// Compute actual (with parasitics)
	result, err := s.SolveMVMWithFallback(appliedVoltages)
	if err != nil && !result.Converged {
		return nil, err
	}

	// Find worst case cell
	var worstCell [2]int
	var maxDrop float64
	for i := 0; i < s.rows; i++ {
		for j := 0; j < s.cols; j++ {
			drop := appliedVoltages[j] - result.DeviceVoltages[i][j]
			if drop > maxDrop {
				maxDrop = drop
				worstCell = [2]int{i, j}
			}
		}
	}

	// Calculate max relative error
	var maxRelErr float64
	for i := range ideal {
		if ideal[i] > 1e-10 {
			relErr := math.Abs(ideal[i]-result.OutputCurrents[i]) / ideal[i]
			if relErr > maxRelErr {
				maxRelErr = relErr
			}
		}
	}

	return &ParasiticImpact{
		Solver:           s,
		IdealOutput:      ideal,
		ActualOutput:     result.OutputCurrents,
		RMSError:         ComputeAccuracyLoss(ideal, result.OutputCurrents),
		MaxRelativeError: maxRelErr,
		IterationsNeeded: result.Iterations,
		WorstCaseCell:    worstCell,
		WorstCaseDropPct: maxDrop / appliedVoltages[worstCell[1]] * 100,
	}, nil
}
